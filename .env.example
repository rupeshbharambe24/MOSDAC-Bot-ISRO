# Neo4j Database Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# LLM Configuration (choose one or both)
# Groq API — fast, free tier, high quality (recommended)
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Local LLM fallback (optional, needs ~4GB model download)
# N_GPU_LAYERS=0

# Optional: Poppler path for PDF processing (system-dependent)
# POPPLER_PATH=C:\Program Files\poppler-24.08.0\Library\bin
